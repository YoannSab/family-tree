rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Legacy flat images (migration source) — read public
    match /family-images/{filename} {
      allow read: if true;
      allow write: if false;
    }
    // Family-scoped images — only authenticated users of that family
    match /family-images/{familyId}/{filename} {
      allow read, write: if request.auth != null && request.auth.token.familyId == familyId;
    }
  }
}
